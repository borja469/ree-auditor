# PostgreSQL
POSTGRES_USER=ree
POSTGRES_PASSWORD=ree
POSTGRES_DB=ree_auditor
DATABASE_URL=postgresql://ree:ree@localhost:5432/ree_auditor?schema=public

# API
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
DATA_DIR=./data
UPLOAD_TMP_DIR=./data/tmp/uploads

# Frontend build
VITE_API_URL=auto

# ESIOS
ESIOS_API_URL=https://api.esios.ree.es
ESIOS_API_TOKEN=
ESIOS_TIMEOUT_SECONDS=60
ESIOS_RETRIES=2

# OMIE SIOM2
OMIE_SIOM2_ENDPOINT=https://www.mercado.omie.es/jsiom/webServices/SIOMServiceRouter
OMIE_SIOM2_P12_PATH=
OMIE_SIOM2_P12_HOST_PATH=./certs/omie-siom2.p12
OMIE_SIOM2_P12_BASE64=
OMIE_SIOM2_P12_PASSPHRASE=
OMIE_SIOM2_REJECT_UNAUTHORIZED=true
OMIE_SIOM2_DNS_SERVERS=1.1.1.1,8.8.8.8
OMIE_SIOM2_TIMEOUT_MS=30000

# OMIE data/cache paths
OMIE_CATALOGO_PATH=./data/omie-catalogo.json
OMIE_CATALOGO_ANALIZADO_PATH=./data/omie-catalogo-analizado.json
OMIE_CATALOGO_PRIORIDADES_PATH=./data/omie-catalogo-prioridades.json
OMIE_PRECIOS_PROGRAMAS_PATH=./data/omie-precios-informe.json
OMIE_PRECIOS_MERCADO_REPORT_PATH=./data/omie-precios-mercado-report.json
OMIE_CUARTOHORARIO_PATH=./data/omie-cuartohorario-report.json
OMIE_DESCARGAS_PDBC_REPORT_PATH=./data/omie-descargas-pdbc-report.json
OMIE_DIAGNOSTICO_ENERGIA_PATH=./data/omie-diagnostico-energia.json
OMIE_DIAGNOSTICO_ENERGIA_PRUEBAS_PATH=./data/omie-pruebas
OMIE_ENERGIA_PHF_SESIONES=01,02,03,04,05,06,07
