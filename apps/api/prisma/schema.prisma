generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReeFileType {
  REGANECU
  REGANECUQH
}

enum ReeSettlementVersion {
  A1
  C1
  C2
  C3
  C4
  C5
}

enum ReeImportStatus {
  IMPORTED
  FAILED
  DUPLICATED
}

enum MedperFileType {
  MEDPERUP
  MEDPERQH
}

enum ReeKFactorFileType {
  KESTIMQH
  KREALQH
}

enum OmieTipoDocumento {
  PVD
  PHF
}

enum OmieDownloadEstado {
  PENDIENTE
  DESCARGANDO
  DESCARGADO
  PROCESADO
  ERROR
}

enum OmieTipoPrecio {
  MD
  MI
  XBID
}

model ReeFile {
  id                 String               @id @default(uuid()) @db.Uuid
  fileName           String               @map("file_name")
  containerFileName  String?              @map("container_file_name")
  fileHash           String               @map("file_hash")
  tipoArchivo        ReeFileType          @map("tipo_archivo")
  version            ReeSettlementVersion
  fechaLiquidacion   DateTime             @map("fecha_liquidacion") @db.Date
  sujetoEic          String               @map("sujeto_eic")
  encoding           String
  delimiter          String
  status             ReeImportStatus      @default(IMPORTED)
  errorMessage       String?              @map("error_message") @db.Text
  originalContent    Bytes?               @map("original_content")
  importedAt         DateTime             @default(now()) @map("imported_at")
  totalRecords       Int                  @default(0) @map("total_records")
  validRecords       Int                  @default(0) @map("valid_records")
  invalidRecords     Int                  @default(0) @map("invalid_records")
  duplicatedRecords  Int                  @default(0) @map("duplicated_records")
  reganecuRecords    ReganecuRecord[]
  reganecuQhRecords  ReganecuQhRecord[]

  @@unique([tipoArchivo, fechaLiquidacion, version])
  @@index([fileHash])
  @@index([tipoArchivo])
  @@index([version])
  @@index([fechaLiquidacion])
  @@index([sujetoEic])
  @@index([importedAt])
  @@map("ree_files")
}

model MedperFile {
  id                 String              @id @default(uuid()) @db.Uuid
  fileName           String              @map("file_name")
  containerFileName  String?             @map("container_file_name")
  fileHash           String              @map("file_hash")
  tipoArchivo        MedperFileType      @map("tipo_archivo")
  version            String
  fechaInicio        DateTime            @map("fecha_inicio") @db.Date
  fechaFin           DateTime            @map("fecha_fin") @db.Date
  sujetoEic          String              @map("sujeto_eic")
  encoding           String
  delimiter          String
  status             ReeImportStatus     @default(IMPORTED)
  errorMessage       String?             @map("error_message") @db.Text
  originalContent    Bytes?              @map("original_content")
  importedAt         DateTime            @default(now()) @map("imported_at")
  totalRecords       Int                 @default(0) @map("total_records")
  validRecords       Int                 @default(0) @map("valid_records")
  invalidRecords     Int                 @default(0) @map("invalid_records")
  duplicatedRecords  Int                 @default(0) @map("duplicated_records")
  medperupRecords    MedperupRecord[]
  medperqhRecords    MedperqhRecord[]

  @@unique([tipoArchivo, fechaInicio, version])
  @@index([fileHash])
  @@index([tipoArchivo])
  @@index([version])
  @@index([fechaInicio])
  @@index([fechaFin])
  @@index([sujetoEic])
  @@index([importedAt])
  @@map("medper_files")
}

model ReganecuRecord {
  id                            String               @id @default(uuid()) @db.Uuid
  fileId                        String               @map("file_id") @db.Uuid
  file                          ReeFile              @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tipoArchivo                   ReeFileType          @map("tipo_archivo")
  version                       ReeSettlementVersion
  fechaLiquidacion              DateTime             @map("fecha_liquidacion") @db.Date
  sujetoEic                     String               @map("sujeto_eic")
  brp                           String?
  fecha                         DateTime?            @db.Date
  hora                          Int?
  codigoUpr                     String?              @map("codigo_upr")
  energiaMwh                    Decimal?             @map("energia_mwh") @db.Decimal(20, 6)
  precioEurMwh                  Decimal?             @map("precio_eur_mwh") @db.Decimal(20, 8)
  importeEur                    Decimal?             @map("importe_eur") @db.Decimal(20, 6)
  codigoAgenteVendedor          String?              @map("codigo_agente_vendedor")
  segmento                      String?
  facturacion                   String?
  eicUpr                        String?              @map("eic_upr")
  cuenta                        String?
  signoImporte                  String?              @map("signo_importe")
  signoMagnitud                 String?              @map("signo_magnitud")
  eicTitular                    String?              @map("eic_titular")
  codigoMagnitud                String?              @map("codigo_magnitud")
  codigoPrecio                  String?              @map("codigo_precio")
  codigoApunte                  String?              @map("codigo_apunte")
  tipoOferta                    String?              @map("tipo_oferta")
  tipoUpr                       String?              @map("tipo_upr")
  energiaContratoBilateralMwh   Decimal?             @map("energia_contrato_bilateral_mwh") @db.Decimal(20, 6)
  sesion                        String?
  importeCalculadoEur           Decimal?             @map("importe_calculado_eur") @db.Decimal(20, 6)
  importeDiferenciaEur          Decimal?             @map("importe_diferencia_eur") @db.Decimal(20, 6)
  importeConsistente            Boolean              @default(true) @map("importe_consistente")
  precioAnomalo                 Boolean              @default(false) @map("precio_anomalo")
  validationErrors              Json?                @map("validation_errors")
  rawPayloadJson                Json                 @map("raw_payload_json")
  rawLine                       String               @map("raw_line") @db.Text
  sourceLineNumber              Int                  @map("source_line_number")
  recordHash                    String               @map("record_hash")
  createdAt                     DateTime             @default(now()) @map("created_at")

  @@unique([recordHash])
  @@index([fecha])
  @@index([fechaLiquidacion])
  @@index([version])
  @@index([segmento])
  @@index([codigoApunte])
  @@index([codigoPrecio])
  @@index([sujetoEic])
  @@index([brp])
  @@index([eicUpr])
  @@index([codigoUpr])
  @@map("reganecu_records")
}

model ReganecuQhRecord {
  id                            String               @id @default(uuid()) @db.Uuid
  fileId                        String               @map("file_id") @db.Uuid
  file                          ReeFile              @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tipoArchivo                   ReeFileType          @map("tipo_archivo")
  version                       ReeSettlementVersion
  fechaLiquidacion              DateTime             @map("fecha_liquidacion") @db.Date
  sujetoEic                     String               @map("sujeto_eic")
  brp                           String?
  fecha                         DateTime?            @db.Date
  hora                          Int?
  codigoUpr                     String?              @map("codigo_upr")
  energiaMwh                    Decimal?             @map("energia_mwh") @db.Decimal(20, 6)
  precioEurMwh                  Decimal?             @map("precio_eur_mwh") @db.Decimal(20, 8)
  importeEur                    Decimal?             @map("importe_eur") @db.Decimal(20, 6)
  codigoAgenteVendedor          String?              @map("codigo_agente_vendedor")
  segmento                      String?
  facturacion                   String?
  eicUpr                        String?              @map("eic_upr")
  cuenta                        String?
  signoImporte                  String?              @map("signo_importe")
  signoMagnitud                 String?              @map("signo_magnitud")
  eicTitular                    String?              @map("eic_titular")
  codigoMagnitud                String?              @map("codigo_magnitud")
  codigoPrecio                  String?              @map("codigo_precio")
  codigoApunte                  String?              @map("codigo_apunte")
  tipoOferta                    String?              @map("tipo_oferta")
  tipoUpr                       String?              @map("tipo_upr")
  energiaContratoBilateralMwh   Decimal?             @map("energia_contrato_bilateral_mwh") @db.Decimal(20, 6)
  campoHora25                   String?              @map("campo_hora_25")
  importeCalculadoEur           Decimal?             @map("importe_calculado_eur") @db.Decimal(20, 6)
  importeDiferenciaEur          Decimal?             @map("importe_diferencia_eur") @db.Decimal(20, 6)
  importeConsistente            Boolean              @default(true) @map("importe_consistente")
  precioAnomalo                 Boolean              @default(false) @map("precio_anomalo")
  validationErrors              Json?                @map("validation_errors")
  rawPayloadJson                Json                 @map("raw_payload_json")
  rawLine                       String               @map("raw_line") @db.Text
  sourceLineNumber              Int                  @map("source_line_number")
  recordHash                    String               @map("record_hash")
  createdAt                     DateTime             @default(now()) @map("created_at")

  @@unique([recordHash])
  @@index([fecha])
  @@index([fechaLiquidacion])
  @@index([version])
  @@index([segmento])
  @@index([codigoApunte])
  @@index([codigoPrecio])
  @@index([sujetoEic])
  @@index([brp])
  @@index([eicUpr])
  @@index([codigoUpr])
  @@map("reganecu_qh_records")
}

model MedperupRecord {
  id                   String          @id @default(uuid()) @db.Uuid
  fileId               String          @map("file_id") @db.Uuid
  file                 MedperFile      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tipoArchivo          MedperFileType  @map("tipo_archivo")
  version              String
  fechaInicio          DateTime        @map("fecha_inicio") @db.Date
  fechaFin             DateTime        @map("fecha_fin") @db.Date
  sujetoEic            String          @map("sujeto_eic")
  fecha                DateTime        @db.Date
  timestamp            DateTime
  hora                 Int
  codigoUpr            String          @map("codigo_upr")
  tipoTarifa           String?         @map("tipo_tarifa")
  codigoNivelTension   String?         @map("codigo_nivel_tension")
  concepto             String?
  medidaMwh            Decimal?        @map("medida_mwh") @db.Decimal(20, 6)
  negativeEnergy       Boolean         @default(false) @map("negative_energy")
  validationErrors     Json?           @map("validation_errors")
  rawPayloadJson       Json            @map("raw_payload_json")
  rawLine              String          @map("raw_line") @db.Text
  sourceLineNumber     Int             @map("source_line_number")
  recordHash           String          @map("record_hash")
  createdAt            DateTime        @default(now()) @map("created_at")

  @@unique([recordHash])
  @@index([fecha])
  @@index([timestamp])
  @@index([version])
  @@index([sujetoEic])
  @@index([codigoUpr])
  @@index([tipoTarifa])
  @@index([codigoNivelTension])
  @@index([concepto])
  @@map("medperup_records")
}

model MedperqhRecord {
  id                   String          @id @default(uuid()) @db.Uuid
  fileId               String          @map("file_id") @db.Uuid
  file                 MedperFile      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tipoArchivo          MedperFileType  @map("tipo_archivo")
  version              String
  fechaInicio          DateTime        @map("fecha_inicio") @db.Date
  fechaFin             DateTime        @map("fecha_fin") @db.Date
  sujetoEic            String          @map("sujeto_eic")
  fecha                DateTime        @db.Date
  timestamp            DateTime
  hora                 Int
  cuartoHora           Int             @map("cuarto_hora")
  codigoUnidad         String          @map("codigo_unidad")
  peaje                String?
  programaEnergiaMwh   Decimal?        @map("programa_energia_mwh") @db.Decimal(20, 6)
  perdidasMwh          Decimal?        @map("perdidas_mwh") @db.Decimal(20, 6)
  bcMwh                Decimal?        @map("bc_mwh") @db.Decimal(20, 6)
  pfMwh                Decimal?        @map("pf_mwh") @db.Decimal(20, 6)
  bcPfDifferenceMwh    Decimal?        @map("bc_pf_difference_mwh") @db.Decimal(20, 6)
  negativeEnergy       Boolean         @default(false) @map("negative_energy")
  bcPfInconsistent     Boolean         @default(false) @map("bc_pf_inconsistent")
  validationErrors     Json?           @map("validation_errors")
  rawPayloadJson       Json            @map("raw_payload_json")
  rawLine              String          @map("raw_line") @db.Text
  sourceLineNumber     Int             @map("source_line_number")
  recordHash           String          @map("record_hash")
  createdAt            DateTime        @default(now()) @map("created_at")

  @@unique([recordHash])
  @@index([fecha])
  @@index([timestamp])
  @@index([version])
  @@index([sujetoEic])
  @@index([codigoUnidad])
  @@index([peaje])
  @@index([negativeEnergy])
  @@index([bcPfInconsistent])
  @@map("medperqh_records")
}

model ImportOverwriteAudit {
  id                 String   @id @default(uuid()) @db.Uuid
  usuario            String
  tipoArchivo        String   @map("tipo_archivo")
  fecha              DateTime @db.Date
  version            String
  replacedFileId     String   @map("replaced_file_id") @db.Uuid
  replacedFileName   String   @map("replaced_file_name")
  replacedImportedAt DateTime @map("replaced_imported_at")
  newFileId          String   @map("new_file_id") @db.Uuid
  newFileName        String   @map("new_file_name")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([tipoArchivo, fecha, version])
  @@index([createdAt])
  @@map("import_overwrite_audits")
}

model PerdidaBoe {
  id                 String   @id @default(uuid()) @db.Uuid
  tarifa             String
  periodo            String
  porcentajePerdida  Decimal  @map("porcentaje_perdida") @db.Decimal(10, 6)
  fechaInicio        DateTime @map("fecha_inicio") @db.Date
  fechaFin           DateTime @map("fecha_fin") @db.Date
  versionBoe         String   @map("version_boe")
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([tarifa, periodo, fechaInicio, fechaFin, versionBoe])
  @@index([tarifa])
  @@index([periodo])
  @@index([fechaInicio, fechaFin])
  @@map("perdidas_boe")
}

model CalendarioFestivo {
  fecha       DateTime @db.Date
  descripcion String
  ambito      String
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([fecha, ambito])
  @@index([ambito])
  @@map("calendario_festivos")
}

model TarifaPeriodo {
  id         String   @id @default(uuid()) @db.Uuid
  tarifa     String
  temporada  String
  tipoDia    String   @map("tipo_dia")
  hora       Int
  cuartohora Int
  periodo    String
  mes        Int
  sistema    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([tarifa, mes, tipoDia, hora, cuartohora, sistema])
  @@index([tarifa])
  @@index([periodo])
  @@index([mes])
  @@index([sistema])
  @@map("tarifas_periodos")
}

model ReeKFactor {
  id          String             @id @default(uuid()) @db.Uuid
  fecha       DateTime           @db.Date
  hora        Int
  cuartohora  Int
  version     ReeSettlementVersion
  tipoArchivo ReeKFactorFileType @map("tipo_archivo")
  tarifa      String
  periodo     String
  valorK      Decimal            @map("valor_k") @db.Decimal(20, 10)
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([fecha])
  @@index([version])
  @@index([tipoArchivo])
  @@index([tarifa])
  @@index([periodo])
  @@index([fecha, hora, cuartohora])
  @@index([fecha, hora, cuartohora, tarifa, periodo])
  @@map("ree_k_factor")
}

model ReeKFactorImport {
  id                String              @id @default(uuid()) @db.Uuid
  fileName          String              @map("file_name")
  containerFileName String?             @map("container_file_name")
  fileHash          String?             @map("file_hash")
  tipoArchivo       ReeKFactorFileType? @map("tipo_archivo")
  version           ReeSettlementVersion?
  fechaInicio       DateTime?           @map("fecha_inicio") @db.Date
  fechaFin          DateTime?           @map("fecha_fin") @db.Date
  status            ReeImportStatus     @default(IMPORTED)
  errorMessage      String?             @map("error_message") @db.Text
  importedAt        DateTime            @default(now()) @map("imported_at")
  totalRecords      Int                 @default(0) @map("total_records")
  validRecords      Int                 @default(0) @map("valid_records")
  invalidRecords    Int                 @default(0) @map("invalid_records")
  duplicatedRecords Int                 @default(0) @map("duplicated_records")

  @@index([version])
  @@index([tipoArchivo])
  @@index([fechaInicio])
  @@index([fechaFin])
  @@index([status])
  @@index([importedAt])
  @@map("ree_k_factor_imports")
}

model OmieDownload {
  id             String              @id @default(uuid()) @db.Uuid
  tipoDocumento  OmieTipoDocumento   @map("tipo_documento")
  fechaPrograma  DateTime            @map("fecha_programa") @db.Date
  sesion         String?
  version        Int                 @default(1)
  uOfertante     String              @default("STROC01") @map("u_ofertante")
  fechaDescarga  DateTime            @map("fecha_descarga")
  estado         OmieDownloadEstado  @default(PENDIENTE)
  registros      Int                 @default(0)
  hashContenido  String?             @map("hash_contenido")
  nombreFichero  String?             @map("nombre_fichero")
  mensajeError   String?             @map("mensaje_error") @db.Text
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  programas      OmiePrograma[]

  @@unique([tipoDocumento, fechaPrograma, sesion, version, uOfertante])
  @@index([fechaPrograma])
  @@index([tipoDocumento])
  @@index([estado])
  @@index([fechaDescarga])
  @@map("omie_downloads")
}

model OmiePrograma {
  id                 String             @id @default(uuid()) @db.Uuid
  tipoPrograma       OmieTipoDocumento  @map("tipo_programa")
  fechaPrograma      DateTime           @map("fecha_programa") @db.Date
  sesion             String?
  version            Int                @default(1)
  uOfertante         String             @map("u_ofertante")
  periodo            Int
  descripcionPeriodo String             @map("descripcion_periodo")
  clave              String
  energiaMWh         Decimal            @map("energia_mwh") @db.Decimal(20, 6)
  fechaDescarga      DateTime           @map("fecha_descarga")
  downloadId         String             @map("download_id") @db.Uuid
  download           OmieDownload       @relation(fields: [downloadId], references: [id], onDelete: Cascade)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@unique([tipoPrograma, fechaPrograma, sesion, version, uOfertante, periodo])
  @@index([fechaPrograma])
  @@index([tipoPrograma])
  @@index([downloadId])
  @@index([clave])
  @@map("omie_programas")
}

model OmieTransactionDownload {
  id                String                    @id @default(uuid()) @db.Uuid
  codigoConsulta    String                    @default("4121") @map("codigo_consulta")
  fechaDesde        DateTime                  @map("fecha_desde") @db.Date
  fechaHasta        DateTime                  @map("fecha_hasta") @db.Date
  fechaDescarga     DateTime                  @map("fecha_descarga")
  estado            OmieDownloadEstado        @default(PENDIENTE)
  registros         Int                       @default(0)
  diasConsultados   Int                       @default(0) @map("dias_consultados")
  columnas          Json?
  resumenEstructura Json?                     @map("resumen_estructura")
  hashContenido     String?                   @map("hash_contenido")
  nombreFichero     String?                   @map("nombre_fichero")
  mensajeError      String?                   @map("mensaje_error") @db.Text
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  stagingRows       OmieTransactionStaging[]

  @@index([codigoConsulta])
  @@index([fechaDesde])
  @@index([fechaHasta])
  @@index([estado])
  @@index([fechaDescarga])
  @@map("omie_transaction_downloads")
}

model OmieTransactionStaging {
  id             String                  @id @default(uuid()) @db.Uuid
  downloadId     String                  @map("download_id") @db.Uuid
  download       OmieTransactionDownload @relation(fields: [downloadId], references: [id], onDelete: Cascade)
  diaContrato    DateTime                @map("dia_contrato") @db.Date
  rowIndex       Int                     @map("row_index")
  rawPayloadJson Json                    @map("raw_payload_json")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  @@unique([downloadId, rowIndex])
  @@index([downloadId])
  @@index([diaContrato])
  @@map("omie_transaction_staging")
}

model OmiePriceDownload {
  id             String              @id @default(uuid()) @db.Uuid
  tipoPrecio     OmieTipoPrecio      @map("tipo_precio")
  fechaPrograma  DateTime            @map("fecha_programa") @db.Date
  sesion         String?
  version        Int                 @default(1)
  fechaDescarga  DateTime            @map("fecha_descarga")
  estado         OmieDownloadEstado  @default(PENDIENTE)
  registros      Int                 @default(0)
  hashContenido  String?             @map("hash_contenido")
  mensajeError   String?             @map("mensaje_error") @db.Text
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  precios        OmiePrice[]

  @@unique([tipoPrecio, fechaPrograma, sesion, version])
  @@index([fechaPrograma])
  @@index([tipoPrecio])
  @@index([estado])
  @@index([fechaDescarga])
  @@map("omie_price_downloads")
}

model OmiePrice {
  id             String             @id @default(uuid()) @db.Uuid
  tipoPrecio     OmieTipoPrecio     @map("tipo_precio")
  fechaPrograma  DateTime           @map("fecha_programa") @db.Date
  sesion         String?
  periodo        Int
  clave          String
  precioEurMWh   Decimal            @map("precio_eur_mwh") @db.Decimal(20, 6)
  fechaDescarga  DateTime           @map("fecha_descarga")
  downloadId     String             @map("download_id") @db.Uuid
  download       OmiePriceDownload  @relation(fields: [downloadId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@unique([tipoPrecio, fechaPrograma, sesion, periodo])
  @@index([fechaPrograma])
  @@index([tipoPrecio])
  @@index([downloadId])
  @@index([clave])
  @@map("omie_prices")
}

model OmieLiquidationInvoice {
  fecha          DateTime @id @db.Date
  facturaCompra Decimal? @map("factura_compra") @db.Decimal(20, 2)
  facturaVenta  Decimal? @map("factura_venta") @db.Decimal(20, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("omie_liquidation_invoices")
}

model OmieAutomationConfig {
  id         Int      @id @default(1)
  active     Boolean  @default(false)
  daysBack   Int      @default(3) @map("days_back")
  session1   String?  @db.VarChar(5)
  session2   String?  @db.VarChar(5)
  session3   String?  @db.VarChar(5)
  lastRunKey String?  @map("last_run_key") @db.VarChar(30)
  lastRunAt  DateTime? @map("last_run_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("omie_automation_config")
}

model EsiosConfig {
  id             Int      @id @default(1)
  apiUrl         String   @default("https://api.esios.ree.es") @map("api_url") @db.VarChar(500)
  apiToken       String?  @map("api_token") @db.Text
  timeoutSeconds Int      @default(60) @map("timeout_seconds")
  retries        Int      @default(3)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("esios_config")
}

model EsiosIndicator {
  id          BigInt                @id @default(autoincrement())
  indicatorId Int                  @unique @map("indicator_id")
  name        String?              @db.VarChar(500)
  description String?              @db.Text
  shortName   String?              @map("short_name") @db.VarChar(255)
  unit        String?              @db.VarChar(100)
  frequency   String?              @db.VarChar(50)
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  values      EsiosIndicatorValue[]
  logs        EsiosDownloadLog[]

  @@map("esios_indicators")
}

model EsiosIndicatorValue {
  id          BigInt         @id @default(autoincrement())
  indicatorId Int           @map("indicator_id")
  indicator   EsiosIndicator @relation(fields: [indicatorId], references: [indicatorId], onDelete: Cascade)
  datetime    DateTime
  datetimeUtc DateTime?      @map("datetime_utc")
  value       Decimal?       @db.Decimal(18, 6)
  geoId       Int?           @map("geo_id")
  geoName     String?        @map("geo_name") @db.VarChar(255)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@unique([indicatorId, datetimeUtc], map: "ux_esios_indicator_values_utc")
  @@index([indicatorId, datetimeUtc])
  @@index([datetime])
  @@map("esios_indicator_values")
}

model EsiosDownloadLog {
  id                 BigInt          @id @default(autoincrement())
  indicatorId        Int?            @map("indicator_id")
  indicator          EsiosIndicator? @relation(fields: [indicatorId], references: [indicatorId], onDelete: SetNull)
  startDate          DateTime?       @map("start_date")
  endDate            DateTime?       @map("end_date")
  downloadedRecords  Int            @default(0) @map("downloaded_records")
  insertedRecords    Int            @default(0) @map("inserted_records")
  updatedRecords     Int            @default(0) @map("updated_records")
  executionTimeMs    Int            @default(0) @map("execution_time_ms")
  status             String         @db.VarChar(50)
  errorMessage       String?        @map("error_message") @db.Text
  createdAt          DateTime       @default(now()) @map("created_at")

  @@index([indicatorId])
  @@index([createdAt])
  @@index([status])
  @@map("esios_download_logs")
}

model EsiosSeriesAutomationConfig {
  id                   Int       @id @default(1)
  active               Boolean   @default(false)
  scheduleTime         String    @default("06:00") @map("schedule_time") @db.VarChar(5)
  daysBack             Int       @default(7) @map("days_back")
  daysForward          Int       @default(0) @map("days_forward")
  selectedIndicatorIds Json      @default("[]") @map("selected_indicator_ids")
  lastRunKey           String?   @map("last_run_key") @db.VarChar(30)
  lastRunAt            DateTime? @map("last_run_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("esios_series_automation_config")
}

model EsiosProfileUpload {
  id           String                    @id @default(uuid()) @db.Uuid
  year         Int
  fileName     String                    @map("file_name")
  uploadedAt   DateTime                  @default(now()) @map("uploaded_at")
  uploadedBy   String?                   @map("uploaded_by")
  status       String                    @db.VarChar(30)
  errorMessage String?                   @map("error_message") @db.Text
  totalRows    Int                       @default(0) @map("total_rows")
  validRows    Int                       @default(0) @map("valid_rows")
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  profiles     EsiosInitialProfile[]
  coefficients EsiosProfileCoefficient[]

  @@index([year])
  @@index([uploadedAt])
  @@index([status])
  @@map("esios_profile_uploads")
}

model EsiosInitialProfile {
  id                String              @id @default(uuid()) @db.Uuid
  year              Int
  month             Int
  day               Int
  hour              Int
  datetime          DateTime
  profile20td       Decimal             @map("profile_20td") @db.Decimal(20, 15)
  profile30td       Decimal             @map("profile_30td") @db.Decimal(20, 15)
  profile30tdve     Decimal             @map("profile_30tdve") @db.Decimal(20, 15)
  referenceDemandMw Decimal             @map("reference_demand_mw") @db.Decimal(20, 6)
  uploadId          String              @map("upload_id") @db.Uuid
  upload            EsiosProfileUpload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@unique([year, month, day, hour], map: "ux_esios_initial_profiles_hour")
  @@index([year])
  @@index([datetime])
  @@index([uploadId])
  @@map("esios_initial_profiles")
}

model EsiosProfileCoefficient {
  id        String              @id @default(uuid()) @db.Uuid
  year      Int
  tariff    String              @db.VarChar(20)
  alpha     Decimal             @db.Decimal(20, 15)
  beta      Decimal             @db.Decimal(20, 15)
  gamma     Decimal             @db.Decimal(20, 15)
  uploadId  String?             @map("upload_id") @db.Uuid
  upload    EsiosProfileUpload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@unique([year, tariff], map: "ux_esios_profile_coefficients_tariff")
  @@index([year])
  @@index([tariff])
  @@index([uploadId])
  @@map("esios_profile_coefficients")
}

model EsiosProfileIntermediateResult {
  id                 String   @id @default(uuid()) @db.Uuid
  year               Int
  datetime           DateTime
  month              Int
  day                Int
  hour               Int
  tariff             String   @db.VarChar(20)
  initialProfile     Decimal  @map("initial_profile") @db.Decimal(20, 15)
  h0                 Decimal  @db.Decimal(20, 15)
  h1                 Decimal  @db.Decimal(20, 15)
  hf                 Decimal  @db.Decimal(20, 15)
  c0                 Decimal  @db.Decimal(20, 15)
  c1                 Decimal  @db.Decimal(20, 15)
  cf                 Decimal  @db.Decimal(20, 15)
  m0                 Decimal  @db.Decimal(20, 15)
  m1                 Decimal  @db.Decimal(20, 15)
  intermediateProfile Decimal @map("intermediate_profile") @db.Decimal(20, 15)
  demandUsedMw       Decimal  @map("demand_used_mw") @db.Decimal(20, 6)
  demandSource       String   @map("demand_source") @db.VarChar(50)
  referenceDemandMw  Decimal  @map("reference_demand_mw") @db.Decimal(20, 6)
  forecastDemandMw   Decimal? @map("forecast_demand_mw") @db.Decimal(20, 6)
  finalDemandMw      Decimal? @map("final_demand_mw") @db.Decimal(20, 6)
  systemDemandMw     Decimal? @map("system_demand_mw") @db.Decimal(20, 6)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([year, datetime, tariff], map: "ux_esios_profile_intermediate_results_datetime_tariff")
  @@index([year])
  @@index([datetime])
  @@index([tariff])
  @@map("esios_profile_intermediate_results")
}

model EsiosReeFinalDemandUpload {
  id             String                 @id @default(uuid()) @db.Uuid
  year           Int
  month          Int
  day            Int?
  periodKey      String?                @unique(map: "ux_esios_ree_final_demand_upload_period_key") @map("period_key")
  fileName       String                 @map("file_name")
  fileHash       String                 @map("file_hash")
  uploadedAt     DateTime               @default(now()) @map("uploaded_at")
  uploadedBy     String?                @map("uploaded_by")
  status         String                 @db.VarChar(30)
  errorMessage   String?                @map("error_message") @db.Text
  totalRows      Int                    @default(0) @map("total_rows")
  validRows      Int                    @default(0) @map("valid_rows")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  rows           EsiosReeFinalDemand[]

  @@index([year])
  @@index([month])
  @@index([year, month, day])
  @@index([uploadedAt])
  @@index([status])
  @@map("esios_ree_final_demand_uploads")
}

model EsiosReeFinalDemand {
  id          String                    @id @default(uuid()) @db.Uuid
  uploadId    String                    @map("upload_id") @db.Uuid
  upload      EsiosReeFinalDemandUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  year        Int
  month       Int
  day         Int
  hour        Int
  datetime    DateTime
  dstFlag     Int?                      @map("dst_flag")
  demandMw    Decimal                   @map("demand_mw") @db.Decimal(20, 6)
  rawLine     String                    @map("raw_line") @db.Text
  sourceLine  Int                       @map("source_line")
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  @@unique([year, month, day, hour], map: "ux_esios_ree_final_demand_hour")
  @@index([datetime])
  @@index([uploadId])
  @@map("esios_ree_final_demands")
}

model EsiosReeFinalProfileUpload {
  id             String                 @id @default(uuid()) @db.Uuid
  year           Int
  month          Int
  fileName       String                 @map("file_name")
  fileHash       String                 @map("file_hash")
  uploadedAt     DateTime               @default(now()) @map("uploaded_at")
  uploadedBy     String?                @map("uploaded_by")
  status         String                 @db.VarChar(30)
  errorMessage   String?                @map("error_message") @db.Text
  totalRows      Int                    @default(0) @map("total_rows")
  validRows      Int                    @default(0) @map("valid_rows")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  rows           EsiosReeFinalProfile[]

  @@unique([year, month], map: "ux_esios_ree_final_profile_upload_month")
  @@index([year])
  @@index([month])
  @@index([uploadedAt])
  @@index([status])
  @@map("esios_ree_final_profile_uploads")
}

model EsiosReeFinalProfile {
  id             String                    @id @default(uuid()) @db.Uuid
  uploadId       String                    @map("upload_id") @db.Uuid
  upload         EsiosReeFinalProfileUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  year           Int
  month          Int
  day            Int
  hour           Int
  datetime       DateTime
  dstFlag        Int?                      @map("dst_flag")
  profile20td    Decimal                   @map("profile_20td") @db.Decimal(20, 15)
  profile30td    Decimal                   @map("profile_30td") @db.Decimal(20, 15)
  profile30tdve  Decimal                   @map("profile_30tdve") @db.Decimal(20, 15)
  rawLine        String                    @map("raw_line") @db.Text
  sourceLine     Int                       @map("source_line")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  @@unique([year, month, day, hour], map: "ux_esios_ree_final_profile_hour")
  @@index([datetime])
  @@index([uploadId])
  @@map("esios_ree_final_profiles")
}

model EsiosProfileCalculationLog {
  id              String   @id @default(uuid()) @db.Uuid
  year            Int
  status          String   @db.VarChar(30)
  startedAt       DateTime @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  executionTimeMs Int?     @map("execution_time_ms")
  rowsProcessed   Int      @default(0) @map("rows_processed")
  errorMessage    String?  @map("error_message") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([year])
  @@index([status])
  @@index([createdAt])
  @@map("esios_profile_calculation_logs")
}
