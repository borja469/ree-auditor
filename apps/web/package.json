{
  "name": "@ree-auditor/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:prod": "npm run build",
    "test:technical-module-v2": "tsc -p tsconfig.test.json && node ./scripts/run-technical-module-v2-tests.cjs",
    "preview": "vite preview",
    "serve:static": "vite preview --host 0.0.0.0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.3.6"
  }
}
